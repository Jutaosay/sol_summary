# ===== sol_summary env template =====
# Copy this file to .env and adjust values per environment.

# Solana RPC endpoint (public RPC is easy to hit 429 under high frequency).
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# SQLite file path.
SOL_SUMMARY_DB=data/sol_summary.db

# Sampling interval in seconds (recommended >= 5 in production).
SOL_SUMMARY_REFRESH_SECONDS=5

# RPC timeout in seconds.
SOL_SUMMARY_REQUEST_TIMEOUT=15

# Optional runtime host/port (for your launcher/process manager).
# SOL_SUMMARY_HOST=0.0.0.0
# SOL_SUMMARY_PORT=8787
